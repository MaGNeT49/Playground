@page "/game/{id:int}"
@rendermode InteractiveServer
@using Playground.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Playground.Services
@inject GameService GameService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@inject IJSRuntime JsRuntime

@if (_game == null)
{
    <div class="alert alert-warning">Игра не найдена</div>
}
else
{
    <div class="game-detail">
        @if (!string.IsNullOrEmpty(_game.BannerUrl))
        {
            <img src="@_game.BannerUrl" class="img-fluid banner" alt="@_game.Title">
        }
        <div class="game-header mt-4">
            <h1>@_game.Title</h1>
            <p class="text-muted">Автор: @_game.Author | Опубликовано: @_game.UploadedAt.ToShortDateString()</p>
            <div class="tags mb-3">
                @foreach (var tag in _game.Tags)
                {
                    <span class="badge bg-secondary me-1">@tag</span>
                }
            </div>
        </div>

        <div class="row">
            <div class="col-md-8">
                <h3>Описание</h3>
                <p>@_game.Description</p>

                @if (_game.Type == GameType.Browser && !string.IsNullOrEmpty(_game.PlayUrl))
                {
                    <h3>Играть онлайн</h3>
                    <div class="game-iframe-container">
                        <iframe src="@_game.PlayUrl" frameborder="0" allowfullscreen></iframe>
                    </div>
                }
                else if (_game.Type == GameType.Build && !string.IsNullOrEmpty(_game.DownloadUrl))
                {
                    <a href="@_game.DownloadUrl" class="btn btn-success btn-lg" download>Скачать билд</a>
                }
            </div>
            <div class="col-md-4">
                @if (!string.IsNullOrEmpty(_game.CoverUrl))
                {
                    <img src="@_game.CoverUrl" class="img-fluid rounded shadow-sm" alt="@_game.Title">
                }
            </div>
        </div>
        
        @if (_isAuthor)
        {
            <div>
                <button class="btn btn-danger" @onclick="DeleteGame">Удалить игру</button>
            </div>
        }
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private Game? _game;
    private bool _isAuthor = false;
    private int _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        _game = await GameService.GetGameById(Id);
        if (_game != null)
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var userIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (userIdClaim != null && int.TryParse(userIdClaim.Value, out _currentUserId))
            {
                _isAuthor = _game.UserId == _currentUserId;
            }
        }
    }
    
    private async Task DeleteGame()
    {
        var confirmed = await JsRuntime.InvokeAsync<bool>("confirm", "Вы уверены, что хотите удалить эту игру?");
        if (confirmed)
        {
            await GameService.DeleteGame(Id, _currentUserId);
            Navigation.NavigateTo("/games");
        }
    }
}