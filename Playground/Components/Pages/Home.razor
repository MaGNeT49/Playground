@page "/"
@using Playground.Models
@using Playground.Services
@inject GameService GameService

<PageTitle>Playground</PageTitle>

<div class="hero-section text-center py-5 mb-4">
    <h1 class="display-4">Добро пожаловать в Playground!</h1>
    <p class="lead">Площадка для игр и творчества</p>
    <a href="/games" class="btn btn-primary btn-lg">Исследовать игры</a>
</div>

<h2>Популярные игры</h2>
<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var game in popularGames)
    {
        <div class="col">
            <div class="card game-card h-100">
                <img src="@game.CoverUrl" class="card-img-top" alt="@game.Title">
                <div class="card-body">
                    <h5 class="card-title">@game.Title</h5>
                    <p class="card-text">@game.Author</p>
                    <NavLink href="@($"/game/{game.Id}")" class="btn btn-primary stretched-link">Подробнее</NavLink>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Game> popularGames = new();

    protected override async Task OnInitializedAsync()
    {
        var allGames = await GameService.GetAllGames();
        popularGames = allGames.Take(3).ToList();
    }
}